<script is:inline>
  (function() {
    function unlock() {
      document.getElementById('gate').style.display = 'none';
      document.getElementById('app').style.display = 'block';
    }

    if (sessionStorage.getItem('pw_ok') === '1') { unlock(); }

    window.gateCheck = function() {
      var val = document.getElementById('pw').value.trim().toLowerCase();
      var err = document.getElementById('gate-err');
      if (val === 'wojciech') {
        sessionStorage.setItem('pw_ok', '1');
        unlock();
      } else {
        err.classList.add('show');
        document.getElementById('pw').value = '';
        setTimeout(function() { err.classList.remove('show'); }, 2000);
      }
    };

    document.getElementById('pw').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') window.gateCheck();
    });

    setTimeout(function() { document.getElementById('pw').focus(); }, 80);
  })();
</script>

