---
import '../styles/global.css';
import '../styles/app.css';
import Gate from '../components/gate/Gate.astro';
import AppsTab from '../components/tabs/AppsTab.astro';
import StackTab from '../components/tabs/StackTab.astro';
import TimelineTab from '../components/tabs/TimelineTab.astro';
import CVTab from '../components/tabs/CVTab.astro';
import ContactTab from '../components/tabs/ContactTab.astro';
---
<!doctype html>
<html lang="en" data-app-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=5.0, viewport-fit=cover">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="WL Apps">
  <meta name="theme-color" content="#faf8f4" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#09090b" media="(prefers-color-scheme: dark)">
  <meta name="description" content="Wojciech Luszczynski - apps, CV, stack and timeline in one workspace.">
  <meta property="og:title" content="Wojciech Luszczynski - Apps">
  <meta property="og:description" content="Apps, CV, stack and timeline - private workspace.">
  <meta property="og:url" content="https://app.wojciech.io">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://app.wojciech.io/og-default.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale" content="en_US">
  <meta property="og:site_name" content="Wojciech Luszczynski">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Wojciech Luszczynski - Apps">
  <meta name="twitter:description" content="Apps, CV, stack and timeline - private workspace.">
  <meta name="twitter:image" content="https://app.wojciech.io/og-default.png">
  <link rel="canonical" href="https://app.wojciech.io">
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="manifest" href="/manifest.json">
  <title>Wojciech Luszczynski - Apps</title>

  <script is:inline>
    // Theme init - runs before paint to prevent flash
    (function() {
      try {
        var saved = localStorage.getItem('appTheme') || localStorage.getItem('gTheme');
        var mode;
        if (saved) {
          mode = saved === 'dark' ? 'dark' : 'light';
        } else {
          mode = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.setAttribute('data-app-theme', mode);
        document.documentElement.style.colorScheme = mode;
      } catch(e) {
        document.documentElement.setAttribute('data-app-theme', 'dark');
      }
      // React to system preference changes when no manual choice is saved
      try {
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
          if (!localStorage.getItem('appTheme') && !localStorage.getItem('gTheme')) {
            var m = e.matches ? 'dark' : 'light';
            document.documentElement.setAttribute('data-app-theme', m);
            document.documentElement.style.colorScheme = m;
          }
        });
      } catch(e) {}
    })();
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&family=Geist+Mono:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body data-app-theme="dark">

<Gate />

<div id="app" style="display:none;">

  <!-- HEADER -->
  <header><div class="hdr-inner">
    <a href="#" class="hdr-brand" onclick="switchTab('apps',document.querySelector('[data-tab=apps]'));return false;">
      <div class="hdr-name">Wojciech Luszczynski</div>
      <div class="hdr-sub" data-pl="Portfolio Projektow" data-en="Apps Portfolio" data-it="Portfolio App">Apps Portfolio</div>
    </a>

    <div style="flex:1"></div>

    <div class="app-theme-toggle" id="appThemeToggle" role="group" aria-label="Theme">
      <button class="app-theme-btn" type="button" data-theme-choice="light" onclick="setAppTheme('light')" aria-pressed="false" title="Light">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4.5"></circle><path d="M12 2.5v3M12 18.5v3M4.25 4.25l2.1 2.1M17.65 17.65l2.1 2.1M2.5 12h3M18.5 12h3M4.25 19.75l2.1-2.1M17.65 6.35l2.1-2.1"></path></svg>
        <span class="theme-label" data-pl="Jasny" data-en="Light" data-it="Chiaro">Light</span>
      </button>
      <button class="app-theme-btn" type="button" data-theme-choice="dark" onclick="setAppTheme('dark')" aria-pressed="false" title="Dark">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.2 14.8a8.3 8.3 0 0 1-10.9-11 8.7 8.7 0 1 0 10.9 11Z"></path></svg>
        <span class="theme-label" data-pl="Ciemny" data-en="Dark" data-it="Scuro">Dark</span>
      </button>
    </div>

    <div class="lang-toggle" id="appLangToggle">
      <button class="lang-btn" id="btnPL" onclick="setLang('pl')">PL</button>
      <button class="lang-btn active" id="btnEN" onclick="setLang('en')">EN</button>
      <button class="lang-btn" id="btnIT" onclick="setLang('it')">IT</button>
    </div>
  </div></header>

  <!-- TAB NAV -->
  <nav class="tab-nav"><div class="tab-nav-inner">
    <button class="tab-btn active" data-tab="apps" onclick="switchTab('apps',this)">
      <span data-pl="Aplikacje" data-en="Apps" data-it="App">Aplikacje</span>
      <span class="t-count" id="tabCount">14</span>
    </button>
    <button class="tab-btn" data-tab="stack" onclick="switchTab('stack',this)">
      <span data-pl="Stack" data-en="Stack" data-it="Stack">Stack</span>
    </button>
    <button class="tab-btn" data-tab="timeline" onclick="switchTab('timeline',this)">
      <span data-pl="Historia" data-en="Timeline" data-it="Timeline">Historia</span>
    </button>
    <button class="tab-btn" data-tab="cv" onclick="switchTab('cv',this)">
      <span data-pl="CV" data-en="CV" data-it="CV">CV</span>
    </button>
    <button class="tab-btn" data-tab="contact" onclick="switchTab('contact',this)">
      <span data-pl="Kontakt" data-en="Contact" data-it="Contatto">Kontakt</span>
    </button>
  </div></nav>

  <!-- MAIN -->
  <main>
    <AppsTab />
    <StackTab />
    <TimelineTab />
    <CVTab />
    <ContactTab />

    <footer>
      <p>&copy; 2026 <span>Wojciech Luszczynski</span> &middot; <a href="mailto:hello@wojciech.io" style="color:var(--text-2);text-decoration:none;">hello@wojciech.io</a></p>
      <div class="footer-socials">
        <a href="https://wojciech.io" target="_blank" class="fsoc" title="Website"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg></a>
        <a href="https://www.linkedin.com/in/wojciech-luszczynski/" target="_blank" class="fsoc" title="LinkedIn"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg></a>
        <a href="https://github.com/wojciechluszczynski" target="_blank" class="fsoc" title="GitHub"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg></a>
        <a href="https://twitter.com/w_luszczynski" target="_blank" class="fsoc" title="Twitter"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg></a>
        <a href="https://substack.com/@luscinetti" target="_blank" class="fsoc" title="Substack"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"></path></svg></a>
      </div>
    </footer>

    <!-- MOBILE BOTTOM NAV -->
    <nav class="mob-nav" aria-label="Navigation">
      <div class="mob-nav-inner">
        <button class="mob-nav-btn tab-btn active" data-tab="apps" onclick="switchTab('apps',this)">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
          <span data-pl="Aplikacje" data-en="Apps" data-it="App">Apps</span>
        </button>
        <button class="mob-nav-btn tab-btn" data-tab="stack" onclick="switchTab('stack',this)">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
          <span>Stack</span>
        </button>
        <button class="mob-nav-btn tab-btn" data-tab="timeline" onclick="switchTab('timeline',this)">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><line x1="3" y1="12" x2="9" y2="12"/><line x1="15" y1="12" x2="21" y2="12"/><line x1="12" y1="3" x2="12" y2="9"/><line x1="12" y1="15" x2="12" y2="21"/></svg>
          <span data-pl="Historia" data-en="Journey" data-it="Percorso">Journey</span>
        </button>
        <button class="mob-nav-btn tab-btn" data-tab="cv" onclick="switchTab('cv',this)">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>CV</span>
        </button>
        <button class="mob-nav-btn tab-btn" data-tab="contact" onclick="switchTab('contact',this)">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span data-pl="Kontakt" data-en="Contact" data-it="Contatto">Contact</span>
        </button>
      </div>
    </nav>
  </main>

</div><!-- /app -->

<script is:inline>
  // ===================== LANG =====================
  var currentLang = 'en';

  function setLang(lang) {
    currentLang = (['pl','en','it'].indexOf(lang) > -1) ? lang : 'en';
    try { localStorage.setItem('appLang', currentLang); } catch(e) {}
    ['btnPL','btnEN','btnIT'].forEach(function(id) {
      var b = document.getElementById(id);
      if (b) b.classList.toggle('active', b.textContent === currentLang.toUpperCase());
    });
    applyLang(currentLang);
  }

  function applyLang(l) {
    if (!l) l = currentLang;
    document.querySelectorAll('[data-pl],[data-en],[data-it]').forEach(function(el) {
      var val = el.getAttribute('data-' + l) || el.getAttribute('data-en');
      if (!val) return;
      if (el.children.length === 0) {
        el.textContent = val;
      } else {
        el.childNodes.forEach(function(node) {
          if (node.nodeType === 3) node.textContent = val;
        });
      }
    });
    document.querySelectorAll('[data-' + l + '-placeholder],[data-en-placeholder]').forEach(function(el) {
      el.placeholder = el.getAttribute('data-' + l + '-placeholder') || el.getAttribute('data-en-placeholder') || '';
    });
    var si = document.getElementById('searchInput');
    if (si) si.placeholder = l === 'pl' ? 'Szukaj aplikacji, tagow...' : (l === 'it' ? 'Cerca app, tag...' : 'Search apps, tags...');
  }

  // Read language from gate / storage
  (function() {
    var saved = '';
    try { saved = localStorage.getItem('appLang') || localStorage.getItem('gLang') || ''; } catch(e) {}
    var detected;
    if (saved && ['pl','en','it'].indexOf(saved) !== -1) {
      detected = saved;
    } else {
      var bl = (navigator.language || 'en').toLowerCase();
      if (bl.startsWith('pl')) { detected = 'pl'; }
      else if (bl.startsWith('it')) { detected = 'it'; }
      else { detected = 'en'; }
    }
    currentLang = detected;
    document.documentElement.setAttribute('lang', detected);
    ['btnPL','btnEN','btnIT'].forEach(function(id) {
      var b = document.getElementById(id);
      if (b) b.classList.toggle('active', b.textContent === detected.toUpperCase());
    });
    applyLang(detected);
  })();

  // ===================== APP THEME =====================
  function readPreferredAppTheme() {
    var saved = '', gate = '';
    try {
      saved = localStorage.getItem('appTheme') || '';
      gate = localStorage.getItem('gTheme') || '';
    } catch(e) {}
    var picked = saved || gate || 'dark';
    return picked === 'dark' ? 'dark' : 'light';
  }

  function updateGateThemeIcon(mode) {
    var icon = document.getElementById('gThemeIcon');
    if (!icon) return;
    icon.innerHTML = mode === 'light'
      ? '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" fill="currentColor" stroke="none"/>'
      : '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
  }

  function setAppTheme(mode) {
    mode = mode === 'dark' ? 'dark' : 'light';
    document.documentElement.setAttribute('data-app-theme', mode);
    document.body.setAttribute('data-app-theme', mode);
    document.documentElement.style.colorScheme = mode;
    try {
      localStorage.setItem('appTheme', mode);
      localStorage.setItem('gTheme', mode);
    } catch(e) {}
    document.querySelectorAll('.app-theme-btn').forEach(function(btn) {
      var active = btn.getAttribute('data-theme-choice') === mode;
      btn.classList.toggle('active', active);
      btn.setAttribute('aria-pressed', active ? 'true' : 'false');
    });
    var gate = document.getElementById('gate');
    if (gate) gate.classList.toggle('light-mode', mode === 'light');
    updateGateThemeIcon(mode);
    document.querySelectorAll('meta[name="theme-color"]').forEach(function(meta) {
      meta.setAttribute('content', mode === 'light' ? '#faf8f4' : '#09090b');
    });
  }

  function initAppTheme() {
    setAppTheme(readPreferredAppTheme());
  }

  initAppTheme();

  // ===================== TABS =====================
  function toggleProj(head) {
    var row = head.parentElement;
    var isOpen = row.classList.contains('open');
    document.querySelectorAll('.proj-row.open').forEach(function(r) { r.classList.remove('open'); });
    if (!isOpen) row.classList.add('open');
  }

  var validTabs = ['apps','docs','stack','timeline','cv','contact'];

  function switchTab(id, btn) {
    if (validTabs.indexOf(id) === -1) id = 'apps';
    document.querySelectorAll('.tab-content').forEach(function(t) {
      t.classList.remove('active');
      t.style.display = 'none';
      t.setAttribute('hidden', '');
      t.setAttribute('aria-hidden', 'true');
    });
    document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
    var target = document.getElementById('tab-' + id);
    if (target) {
      target.classList.add('active');
      target.style.display = 'block';
      target.removeAttribute('hidden');
      target.setAttribute('aria-hidden', 'false');
    }
    if (btn) {
      btn.classList.add('active');
    } else {
      document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.toggle('active', b.getAttribute('data-tab') === id);
      });
    }
    window.scrollTo(0, 0);
    history.pushState({tab: id}, '', '/' + id);
    if (id === 'cv') setTimeout(animateKPIs, 120);
  }

  // Init from URL pathname on load
  (function() {
    var path = window.location.pathname.replace(/^\//, '').replace(/\/$/, '');
    var tab = validTabs.indexOf(path) > -1 ? path : 'apps';
    var tc = document.getElementById('tab-' + tab);
    document.querySelectorAll('.tab-content').forEach(function(t) {
      t.classList.remove('active');
      t.style.display = 'none';
      t.setAttribute('hidden', '');
      t.setAttribute('aria-hidden', 'true');
    });
    if (tc) {
      tc.classList.add('active');
      tc.style.display = 'block';
      tc.removeAttribute('hidden');
      tc.setAttribute('aria-hidden', 'false');
    }
    document.querySelectorAll('.tab-btn').forEach(function(b) {
      b.classList.toggle('active', b.getAttribute('data-tab') === tab);
    });
    history.replaceState({tab: tab}, '', '/' + tab);
    window.addEventListener('popstate', function(e) {
      if (e.state && e.state.tab) switchTab(e.state.tab, null);
    });
  })();

  // ===================== FILTER / SEARCH =====================
  var activeFilter = 'all';

  function setFilter(f, el) {
    activeFilter = f;
    document.querySelectorAll('.chip').forEach(function(c) { c.classList.remove('active'); });
    el.classList.add('active');
    filterApps();
  }

  function filterApps() {
    var q = (document.getElementById('searchInput') ? document.getElementById('searchInput').value : '').toLowerCase().trim();
    var cards = document.querySelectorAll('#appGrid .app-card');
    var count = 0;
    cards.forEach(function(card) {
      var titleEl = card.querySelector('.card-title');
      var taglineEl = card.querySelector('.card-tagline');
      var uspEl = card.querySelector('.usp-list');
      var txt = [card.dataset.name, card.dataset.tags,
        titleEl ? titleEl.textContent : '',
        taglineEl ? taglineEl.textContent : '',
        uspEl ? uspEl.textContent : ''
      ].filter(Boolean).join(' ').toLowerCase();
      var mS = !q || txt.includes(q);
      var mF = activeFilter === 'all' || (card.dataset.tags && card.dataset.tags.includes(activeFilter));
      var show = mS && mF && !card.dataset.hidden;
      card.style.display = show ? '' : 'none';
      if (show) count++;
    });
    var label = currentLang === 'pl'
      ? count + (count === 1 ? ' wynik' : ' wyniki')
      : count + (count === 1 ? ' result' : ' results');
    var visEl = document.getElementById('visCount');
    var tabEl = document.getElementById('tabCount');
    var statEl = document.getElementById('statApps');
    var noEl = document.getElementById('noResults');
    if (visEl) visEl.textContent = label;
    if (tabEl) tabEl.textContent = count;
    if (statEl) statEl.textContent = count;
    if (noEl) noEl.style.display = count === 0 ? '' : 'none';
  }

  // ===================== STACK FILTER =====================
  function filterStack(tech, btn) {
    document.querySelectorAll('.stack-flt').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    document.querySelectorAll('.proj-row').forEach(function(row) {
      if (tech === 'all') {
        row.style.display = '';
      } else {
        var tags = (row.getAttribute('data-tech') || '').toLowerCase();
        var match = tech === 'lovable' ? (tags.includes('lovable') || tags.includes('base44')) : tags.includes(tech);
        row.style.display = match ? '' : 'none';
      }
    });
  }

  // ===================== CONTACT FORM =====================
  function cfSubmit() {
    var errEl = document.getElementById('intakeError');
    var btn = document.getElementById('intakeSubmitBtn');
    var nameEl = document.getElementById('intakeName');
    var emailEl = document.getElementById('intakeEmail');
    var messageEl = document.getElementById('intakeMessage');
    if (errEl) errEl.style.display = 'none';
    var name = (nameEl ? nameEl.value : '').trim();
    var email = (emailEl ? emailEl.value : '').trim();
    var message = (messageEl ? messageEl.value : '').trim();
    var type = Array.from(document.querySelectorAll('input[name="projectNeed"]:checked')).map(function(el) { return el.value; }).join(', ');
    var timeline = ((document.getElementById('formTimeline') || {}).value || '').trim();
    var source = ((document.getElementById('formSource') || {}).value || '').trim();
    if (!name) { if (errEl) { errEl.textContent = 'Please enter your name.'; errEl.style.display = 'block'; } if (nameEl) nameEl.focus(); return; }
    if (!email || !email.match(/^[^\s@]+@[^\s@]+\.[^\s@]+$/)) { if (errEl) { errEl.textContent = 'Please enter a valid email.'; errEl.style.display = 'block'; } if (emailEl) emailEl.focus(); return; }
    if (!message || message.length < 5) { if (errEl) { errEl.textContent = 'Please write a short message.'; errEl.style.display = 'block'; } if (messageEl) messageEl.focus(); return; }
    var fullMessage = [
      type ? 'Need: ' + type : '',
      timeline ? 'Timeline: ' + timeline : '',
      source ? 'Context: ' + source : '',
      '',
      message
    ].filter(Boolean).join('\n');
    if (btn) btn.disabled = true;
    var spanEl = btn ? btn.querySelector('span') : null;
    if (spanEl) spanEl.textContent = 'Sending...';
    fetch('https://formspree.io/f/xdkondap', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ name: name, email: email, type: type, timeline: timeline, source: source, message: fullMessage })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.ok || data.next) {
        var formWrap = document.getElementById('contactFormWrap');
        var success = document.getElementById('formSuccess');
        if (formWrap) formWrap.style.display = 'none';
        if (success) success.style.display = 'flex';
      } else {
        cfMailtoFallback(name, email, fullMessage);
      }
    })
    .catch(function() {
      cfMailtoFallback(name, email, fullMessage);
    });
  }

  function cfMailtoFallback(name, email, message) {
    var subject = encodeURIComponent('Message from ' + name);
    var body = encodeURIComponent('Name: ' + name + '\nEmail: ' + email + '\n\n' + message);
    window.open('mailto:hello@wojciech.io?subject=' + subject + '&body=' + body);
    var formWrap = document.getElementById('contactFormWrap');
    var success = document.getElementById('formSuccess');
    if (formWrap) formWrap.style.display = 'none';
    if (success) success.style.display = 'flex';
  }

  function subscribeNewsletter() {
    var input = document.getElementById('nlEmail');
    var email = (input ? input.value : '').trim();
    if (!email || !email.match(/^[^\s@]+@[^\s@]+\.[^\s@]+$/)) {
      if (input) input.focus(); return;
    }
    fetch('https://formspree.io/f/xdkondap', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ newsletter: true, email: email })
    }).then(function() {
      if (input) { input.value = ''; input.placeholder = 'Subscribed!'; }
    }).catch(function() {
      if (input) { input.value = ''; input.placeholder = 'Done!'; }
    });
  }

  // ===================== CV =====================
  function toggleAcc(header) {
    var body = header.nextElementSibling;
    var isOpen = header.classList.contains('open');
    header.classList.toggle('open', !isOpen);
    body.classList.toggle('open', !isOpen);
  }

  function filterRoles(type, btn) {
    document.querySelectorAll('.cv-filter-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    document.querySelectorAll('.cv-role').forEach(function(r) {
      if (type === 'all' || r.dataset.roleType === type) r.classList.remove('hidden');
      else r.classList.add('hidden');
    });
  }

  function toggleRole(header) {
    var role = header && header.closest ? header.closest('.cv-role') : null;
    if (!role) return;
    var open = !role.classList.contains('open');
    role.classList.toggle('open', open);
    header.setAttribute('aria-expanded', open ? 'true' : 'false');
  }

  function initCvRoles() {
    document.querySelectorAll('#tab-cv .cv-role').forEach(function(role) {
      var header = role.querySelector('.cv-role-head');
      var bullets = role.querySelector('.cv-role-bullets');
      if (!header || !bullets) return;
      if (!header.dataset.cvAccordionReady) {
        header.dataset.cvAccordionReady = '1';
        header.setAttribute('role', 'button');
        header.setAttribute('tabindex', '0');
        header.addEventListener('click', function() { toggleRole(header); });
        header.addEventListener('keydown', function(event) {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            toggleRole(header);
          }
        });
      }
      role.classList.toggle('open', false);
      header.setAttribute('aria-expanded', 'false');
    });
  }
  initCvRoles();

  function animateKPIs() {
    document.querySelectorAll('#tab-cv .cv-kpi-val').forEach(function(el, i) {
      el.style.animationDelay = (i * 0.12) + 's';
      el.classList.remove('animated');
      void el.offsetWidth;
      el.classList.add('animated');
    });
  }

  // Init
  setLang(currentLang);
  filterApps();
</script>

</body>
</html>
