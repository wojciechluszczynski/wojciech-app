      <!-- Search bar -->
      <div class="apps-search-wrap">
        <div class="apps-search-inner">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input type="text" id="searchInput" placeholder="Search apps, tags..." oninput="filterApps()" autocomplete="off">
        </div>
      </div>

      <!-- Filters -->
      <div class="filters-row" style="margin-top:14px">
        <span class="f-lbl" data-pl="Filtruj:" data-en="Filter:" data-it="Filtra:">Filtruj:</span>
        <button class="chip active" onclick="setFilter('all',this)" data-pl="Wszystkie" data-en="All" data-it="Tutti">All</button>
        <button class="chip" onclick="setFilter('b2b',this)" data-pl="B2B / SaaS" data-en="B2B / SaaS" data-it="B2B / SaaS">B2B / SaaS</button>
        <button class="chip" onclick="setFilter('consumer',this)" data-pl="Consumer Apps" data-en="Consumer Apps" data-it="App Consumer">Consumer Apps</button>
        <button class="chip" onclick="setFilter('booking',this)" data-pl="Booking / E-commerce" data-en="Booking / E-commerce" data-it="Booking / E-commerce">Booking / E-commerce</button>
        <button class="chip" onclick="setFilter('brand',this)" data-pl="Brand Sites" data-en="Brand Sites" data-it="Siti Brand">Brand Sites</button>
        <button class="chip" onclick="setFilter('productivity',this)" data-pl="Productivity" data-en="Productivity" data-it="Produttivita">Productivity</button>
