---
// Private status page — no navigation, password-gated same as main app
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Status — wojciech.io ecosystem</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg:        #F3F2EF;
      --bg1:       #FFFFFF;
      --bg2:       #F0EFEC;
      --bg3:       #E8E7E4;
      --lime:      #EBFF00;
      --lime-dim:  rgba(235,255,0,0.14);
      --lime-glow: rgba(235,255,0,0.25);
      --green:     #10b36c;
      --green-dim: rgba(16,179,108,0.10);
      --blue:      #2563eb;
      --blue-dim:  rgba(37,99,235,0.10);
      --amber:     #b45309;
      --amber-dim: rgba(180,83,9,0.10);
      --border:    rgba(0,0,0,0.08);
      --border-hi: rgba(0,0,0,0.15);
      --text:      #080808;
      --text-2:    #555555;
      --text-3:    #888888;
      --r-card:    18px;
      --r-btn:     99px;
    }
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body {
      background:var(--bg); color:var(--text);
      font-family:'Inter',sans-serif; min-height:100vh;
    }

    /* Gate */
    #gate {
      position:fixed; inset:0; z-index:9999;
      background:var(--bg);
      display:flex; align-items:center; justify-content:center; flex-direction:column; padding:24px;
    }
    .gate-logo { display:inline-flex; align-items:center; gap:8px; margin-bottom:40px; }
    .gate-dot { width:9px; height:9px; border-radius:50%; background:var(--lime); box-shadow:0 0 12px var(--lime-glow); }
    .gate-name { font-size:13px; font-weight:800; letter-spacing:2px; text-transform:uppercase; }
    .gate-inner { width:100%; max-width:360px; text-align:center; }
    .gate-title { font-size:26px; font-weight:900; letter-spacing:-0.5px; margin-bottom:6px; }
    .gate-sub { font-size:14px; color:var(--text-2); margin-bottom:28px; }
    .gate-input {
      width:100%; padding:15px 18px; background:var(--bg1);
      border:1px solid var(--border); border-radius:14px;
      color:var(--text); font-size:15px; font-family:'Inter',sans-serif;
      font-weight:500; outline:none; letter-spacing:2px; margin-bottom:12px;
      transition:border-color .2s;
    }
    .gate-input:focus { border-color:var(--lime); }
    .gate-input::placeholder { color:var(--text-3); letter-spacing:0; }
    .gate-btn {
      width:100%; padding:15px; background:var(--lime); color:#0f0f0f;
      font-size:14px; font-weight:900; font-family:'Inter',sans-serif;
      letter-spacing:0.5px; border:none; border-radius:var(--r-btn);
      cursor:pointer; transition:all .15s;
    }
    .gate-btn:hover { background:#D4E600; transform:translateY(-1px); }
    .gate-err { margin-top:10px; font-size:13px; color:#ff5f5f; font-weight:600; opacity:0; transition:opacity .2s; }
    .gate-err.show { opacity:1; }

    /* App shell */
    #app { display:none; }

    /* Header */
    .st-header {
      position:sticky; top:0; z-index:100;
      background:rgba(243,242,239,0.95);
      backdrop-filter:blur(20px) saturate(180%);
      border-bottom:1px solid var(--border);
      height:60px;
    }
    .st-header-inner {
      max-width:1200px; margin:0 auto;
      padding:0 clamp(16px,4vw,48px);
      height:100%; display:flex; align-items:center; justify-content:space-between;
    }
    .st-logo { display:flex; align-items:center; gap:8px; text-decoration:none; }
    .st-logo-dot { width:8px; height:8px; border-radius:50%; background:var(--lime); }
    .st-logo-name { font-size:13px; font-weight:800; letter-spacing:1.5px; text-transform:uppercase; color:var(--text); }
    .st-badge {
      font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em;
      background:var(--bg3); color:var(--text-3); border-radius:6px; padding:3px 8px;
    }

    /* Page */
    .st-page { max-width:1200px; margin:0 auto; padding:clamp(24px,4vw,48px) clamp(16px,4vw,48px); }
    .st-section-title {
      font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase;
      color:var(--text-3); margin-bottom:20px;
    }
    .st-page-title {
      font-size:clamp(24px,4vw,36px); font-weight:900; letter-spacing:-0.5px;
      margin-bottom:6px;
    }
    .st-page-sub { font-size:15px; color:var(--text-2); margin-bottom:40px; }
    .st-topline {
      display:flex; align-items:center; flex-wrap:wrap; gap:8px;
      margin-bottom:16px;
    }
    .st-chip {
      display:inline-flex; align-items:center; gap:7px;
      height:30px; padding:0 11px; border:1px solid var(--border);
      border-radius:999px; background:var(--bg1);
      color:var(--text-2); font-size:11px; font-weight:800;
      letter-spacing:0.04em; text-transform:uppercase;
    }
    .st-chip-dot {
      width:7px; height:7px; border-radius:999px;
      background:var(--green); box-shadow:0 0 0 4px var(--green-dim);
    }

    /* Overview */
    .st-overview {
      display:grid; grid-template-columns:1.15fr 0.85fr;
      gap:20px; margin-bottom:48px;
    }
    .st-hero-card {
      min-height:280px; position:relative; overflow:hidden;
      border:1px solid var(--border); border-radius:var(--r-card);
      background:linear-gradient(135deg,#090909 0%,#2c2c2c 54%,#f2f0ea 54%,#ffffff 100%);
      color:#fff; padding:28px;
      display:flex; flex-direction:column; justify-content:space-between;
    }
    .st-hero-card::after {
      content:""; position:absolute; inset:auto -60px -120px auto;
      width:320px; height:320px; border-radius:50%;
      background:var(--lime); opacity:0.85;
    }
    .st-hero-copy { position:relative; z-index:1; max-width:520px; }
    .st-hero-eyebrow {
      display:inline-flex; align-items:center; gap:8px;
      height:28px; padding:0 11px; border-radius:999px;
      background:rgba(255,255,255,0.12); color:rgba(255,255,255,0.82);
      font-size:10px; font-weight:900; letter-spacing:0.11em; text-transform:uppercase;
      margin-bottom:18px;
    }
    .st-hero-title {
      font-size:clamp(26px,4.4vw,48px); line-height:0.96;
      letter-spacing:-1px; font-weight:900; margin-bottom:14px;
    }
    .st-hero-text {
      color:rgba(255,255,255,0.72); font-size:14px; line-height:1.7;
      max-width:460px;
    }
    .st-hero-media {
      position:absolute; right:26px; bottom:22px; z-index:1;
      display:grid; grid-template-columns:86px 86px; gap:10px;
    }
    .st-hero-media img {
      width:86px; height:86px; object-fit:cover; border-radius:14px;
      border:1px solid rgba(255,255,255,0.34);
      box-shadow:0 16px 40px rgba(0,0,0,0.22);
      background:#fff;
    }
    .st-hero-media img:first-child { grid-row:span 2; height:182px; }
    .st-stat-grid {
      display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:12px;
    }
    .st-stat {
      background:var(--bg1); border:1px solid var(--border);
      border-radius:var(--r-card); padding:18px; min-height:126px;
      display:flex; flex-direction:column; justify-content:space-between;
    }
    .st-stat-value { font-size:28px; font-weight:900; letter-spacing:-0.5px; }
    .st-stat-label {
      font-size:10px; font-weight:800; color:var(--text-3);
      letter-spacing:0.11em; text-transform:uppercase;
    }
    .st-stat-note { font-size:11px; line-height:1.5; color:var(--text-2); }

    /* Activity cards */
    .st-activity-grid {
      display:grid; grid-template-columns:repeat(3,minmax(0,1fr));
      gap:16px; margin-bottom:48px;
    }
    .st-activity-card {
      background:var(--bg1); border:1px solid var(--border);
      border-radius:var(--r-card); overflow:hidden;
      display:flex; flex-direction:column; min-height:100%;
    }
    .st-activity-visual {
      position:relative; min-height:118px; overflow:hidden;
      background:linear-gradient(135deg,var(--bg3),var(--bg1));
    }
    .st-activity-visual img {
      width:100%; height:118px; object-fit:cover; display:block;
      filter:saturate(0.88) contrast(1.04);
    }
    .st-activity-visual::after {
      content:""; position:absolute; inset:0;
      background:linear-gradient(180deg,rgba(0,0,0,0.04),rgba(0,0,0,0.44));
    }
    .st-activity-icon {
      position:absolute; left:14px; bottom:12px; z-index:1;
      width:40px; height:40px; border-radius:12px;
      display:grid; place-items:center;
      background:rgba(255,255,255,0.92); color:#090909;
      border:1px solid rgba(255,255,255,0.65);
      font-size:13px; font-weight:900; letter-spacing:-0.3px;
      box-shadow:0 10px 24px rgba(0,0,0,0.18);
    }
    .st-activity-body { padding:18px; display:flex; flex-direction:column; gap:14px; }
    .st-activity-top {
      display:flex; align-items:flex-start; justify-content:space-between;
      gap:12px;
    }
    .st-activity-title { font-size:15px; font-weight:900; letter-spacing:-0.2px; }
    .st-activity-meta { font-size:11px; color:var(--text-3); margin-top:3px; }
    .st-status-pill {
      display:inline-flex; align-items:center; gap:6px;
      padding:5px 9px; border-radius:999px;
      font-size:10px; font-weight:900; letter-spacing:0.08em; text-transform:uppercase;
      white-space:nowrap;
    }
    .st-status-pill.done { color:var(--green); background:var(--green-dim); }
    .st-status-pill.report { color:var(--blue); background:var(--blue-dim); }
    .st-status-pill.watch { color:var(--amber); background:var(--amber-dim); }
    .st-status-pill::before {
      content:""; width:6px; height:6px; border-radius:999px; background:currentColor;
    }
    .st-activity-list { list-style:none; display:grid; gap:9px; }
    .st-activity-list li {
      position:relative; padding-left:16px;
      font-size:12px; line-height:1.5; color:var(--text-2);
    }
    .st-activity-list li::before {
      content:""; position:absolute; left:0; top:0.62em;
      width:6px; height:6px; border-radius:999px; background:var(--lime);
      box-shadow:0 0 0 3px var(--lime-dim);
    }

    /* Cards grid */
    .st-grid {
      display:grid;
      grid-template-columns:repeat(auto-fill,minmax(340px,1fr));
      gap:20px;
      margin-bottom:48px;
    }

    /* Site card */
    .st-card {
      background:var(--bg1); border:1px solid var(--border);
      border-radius:var(--r-card); padding:24px; overflow:hidden;
      transition:box-shadow .2s;
    }
    .st-card:hover { box-shadow:0 4px 24px rgba(0,0,0,0.07); }
    .st-card-head { display:flex; align-items:flex-start; justify-content:space-between; gap:12px; margin-bottom:16px; }
    .st-card-meta {}
    .st-card-domain {
      font-size:13px; font-weight:700; color:var(--text);
      text-decoration:none; display:inline-block; margin-bottom:4px;
    }
    .st-card-domain:hover { color:var(--text-2); }
    .st-card-stack { font-size:11px; color:var(--text-3); font-weight:500; }
    .st-card-status {
      display:flex; align-items:center; gap:5px;
      font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.08em;
      padding:4px 10px; border-radius:99px; white-space:nowrap; flex-shrink:0;
    }
    .st-card-status.live {
      background:var(--green-dim); color:var(--green);
    }
    .st-card-status-dot { width:6px; height:6px; border-radius:50%; background:currentColor; }

    .st-card-divider { border:none; border-top:1px solid var(--border); margin:16px 0; }

    /* Changelog */
    .st-changelog { list-style:none; display:flex; flex-direction:column; gap:10px; }
    .st-cl-item { display:flex; gap:12px; }
    .st-cl-date {
      font-size:10px; font-weight:600; color:var(--text-3);
      white-space:nowrap; padding-top:2px; min-width:52px;
    }
    .st-cl-body {}
    .st-cl-tag {
      display:inline-block; font-size:9px; font-weight:700; text-transform:uppercase;
      letter-spacing:0.1em; padding:2px 6px; border-radius:4px; margin-bottom:3px;
    }
    .st-cl-tag.feat { background:var(--lime-dim); color:#5a6200; }
    .st-cl-tag.fix { background:rgba(16,179,108,0.12); color:#0a7a4a; }
    .st-cl-tag.copy { background:rgba(0,0,0,0.06); color:var(--text-3); }
    .st-cl-tag.sync { background:rgba(99,102,241,0.10); color:#4f46e5; }
    .st-cl-text { font-size:12px; color:var(--text-2); line-height:1.5; }

    /* Sprint summary table */
    .st-table-wrap { overflow-x:auto; margin-bottom:48px; }
    table.st-table {
      width:100%; border-collapse:collapse;
      font-size:12px;
    }
    .st-table th {
      text-align:left; padding:10px 14px;
      font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em;
      color:var(--text-3); border-bottom:1px solid var(--border);
      background:var(--bg2);
    }
    .st-table td {
      padding:12px 14px; border-bottom:1px solid var(--border);
      color:var(--text-2); vertical-align:top; line-height:1.5;
    }
    .st-table tr:last-child td { border-bottom:none; }
    .st-table tr:hover td { background:var(--bg2); }
    .st-table .site-col { font-weight:700; color:var(--text); white-space:nowrap; }
    .st-table .check { color:var(--green); font-weight:700; }

    @media(max-width:600px) {
      .st-grid { grid-template-columns:1fr; }
      .st-overview { grid-template-columns:1fr; }
      .st-activity-grid { grid-template-columns:1fr; }
      .st-hero-card { min-height:360px; padding:22px; }
      .st-hero-media { right:18px; bottom:18px; }
      .st-stat-grid { grid-template-columns:1fr; }
    }
    @media(min-width:601px) and (max-width:980px) {
      .st-overview { grid-template-columns:1fr; }
      .st-activity-grid { grid-template-columns:repeat(2,minmax(0,1fr)); }
    }
  </style>
</head>
<body>

<!-- Gate -->
<div id="gate">
  <div class="gate-logo">
    <div class="gate-dot"></div>
    <span class="gate-name">Status</span>
  </div>
  <div class="gate-inner">
    <h1 class="gate-title">Private access</h1>
    <p class="gate-sub">ecosystem status · changelog · sprints</p>
    <input id="pw" type="password" class="gate-input" placeholder="Password" autocomplete="current-password" />
    <button class="gate-btn" onclick="gateCheck()">Enter</button>
    <p class="gate-err" id="gate-err">Wrong password</p>
  </div>
</div>

<!-- App -->
<div id="app">

  <header class="st-header">
    <div class="st-header-inner">
      <a href="/" class="st-logo">
        <div class="st-logo-dot"></div>
        <span class="st-logo-name">wojciech.io</span>
      </a>
      <span class="st-badge">Status · Private</span>
    </div>
  </header>

  <main class="st-page">
    <p class="st-section-title">Ecosystem · 2026-05</p>
    <h1 class="st-page-title">Site status &amp; changelog</h1>
    <div class="st-topline">
      <span class="st-chip"><span class="st-chip-dot"></span>Last content update: 2026-05-17 23:05 CEST</span>
      <span class="st-chip">Latest pushed commit: 470faa6</span>
      <span class="st-chip">Source: main</span>
    </div>
    <p class="st-page-sub">All changes shipped across the wojciech.io ecosystem and adjacent account work — grouped by project, status, date and concrete output.</p>

    <!-- Overview -->
    <section class="st-overview" aria-label="Today overview">
      <div class="st-hero-card">
        <div class="st-hero-copy">
          <span class="st-hero-eyebrow">Account changelog · 2026-05-17</span>
          <h2 class="st-hero-title">What happened today</h2>
          <p class="st-hero-text">A single private dashboard for the work done on this account today: production site updates, PMI visual work, portfolio cleanup, ecosystem identity files, security review, product starter and Apple-first running coach MVP.</p>
        </div>
        <div class="st-hero-media" aria-hidden="true">
          <img src="/wojciech-photo.png" alt="" loading="lazy" />
          <img src="/og-default.png" alt="" loading="lazy" />
          <img src="/favicon-512x512.png" alt="" loading="lazy" />
        </div>
      </div>

      <div class="st-stat-grid" aria-label="Current status">
        <div class="st-stat">
          <div>
            <div class="st-stat-value">8</div>
            <div class="st-stat-label">Active threads</div>
          </div>
          <p class="st-stat-note">Ecosystem, PMI, GitHub security, system health starter, coach MVP and current status polish.</p>
        </div>
        <div class="st-stat">
          <div>
            <div class="st-stat-value">6</div>
            <div class="st-stat-label">Projects grouped</div>
          </div>
          <p class="st-stat-note">PMI, portfolio, app, subdomains, audit/reporting, product MVPs.</p>
        </div>
        <div class="st-stat">
          <div>
            <div class="st-stat-value">23:00</div>
            <div class="st-stat-label">Last pushed</div>
          </div>
          <p class="st-stat-note">Latest status UI update was pushed to <code>wojciech-app</code> at 23:00 CEST.</p>
        </div>
        <div class="st-stat">
          <div>
            <div class="st-stat-value">23:05</div>
            <div class="st-stat-label">Latest edit</div>
          </div>
          <p class="st-stat-note">Cloudflare Pages live check was verified at 23:05 CEST.</p>
        </div>
      </div>
    </section>

    <!-- Account activity -->
    <p class="st-section-title">Account activity — readable project changelog</p>
    <section class="st-activity-grid" aria-label="Project changelog">
      <article class="st-activity-card">
        <div class="st-activity-visual">
          <img src="/og-default.png" alt="" loading="lazy" />
          <div class="st-activity-icon">PMI</div>
        </div>
        <div class="st-activity-body">
          <div class="st-activity-top">
            <div>
              <h2 class="st-activity-title">PMI Investment</h2>
              <p class="st-activity-meta">Last change: 2026-05-17 18:29 CEST · acd3622</p>
            </div>
            <span class="st-status-pill done">Shipped</span>
          </div>
          <ul class="st-activity-list">
            <li>Investor/reporting path added with homepage reports teaser and <code>/dla-inwestorow</code> links.</li>
            <li>Interactive map, tenant logos, realization images and hover crossfades added.</li>
            <li>Navbar, footer, stats, CTA overlay, testimonials and card heights stabilized.</li>
          </ul>
        </div>
      </article>

      <article class="st-activity-card">
        <div class="st-activity-visual">
          <img src="/wojciech-photo.png" alt="" loading="lazy" />
          <div class="st-activity-icon">W</div>
        </div>
        <div class="st-activity-body">
          <div class="st-activity-top">
            <div>
              <h2 class="st-activity-title">wojciech.io portfolio</h2>
              <p class="st-activity-meta">Last change: 2026-05-17 18:45 CEST · 5464e5c</p>
            </div>
            <span class="st-status-pill done">Live</span>
          </div>
          <ul class="st-activity-list">
            <li>Footer rebuilt into SEO and LLM-friendly columns with ecosystem crosslinks.</li>
            <li>12 insight slugs renamed; broken links and author context fixed.</li>
            <li>Hero, now/contact/about copy, CV data and visual details cleaned up.</li>
          </ul>
        </div>
      </article>

      <article class="st-activity-card">
        <div class="st-activity-visual">
          <img src="/favicon-512x512.png" alt="" loading="lazy" />
          <div class="st-activity-icon">APP</div>
        </div>
        <div class="st-activity-body">
          <div class="st-activity-top">
            <div>
              <h2 class="st-activity-title">app.wojciech.io</h2>
              <p class="st-activity-meta">Last pushed: 2026-05-17 23:00 CEST · 470faa6</p>
            </div>
            <span class="st-status-pill done">Live</span>
          </div>
          <ul class="st-activity-list">
            <li>Private <code>/status</code> page added with the same session gate as the main app.</li>
            <li>Original app restored, migrated to Astro and aligned with the ecosystem identity files.</li>
            <li>Current pass adds clearer status, icons, imagery and per-project changelog structure.</li>
          </ul>
        </div>
      </article>

      <article class="st-activity-card">
        <div class="st-activity-visual">
          <img src="/og-default.png" alt="" loading="lazy" />
          <div class="st-activity-icon">GH</div>
        </div>
        <div class="st-activity-body">
          <div class="st-activity-top">
            <div>
              <h2 class="st-activity-title">GitHub security review</h2>
              <p class="st-activity-meta">Reports updated: 2026-05-17 13:01 CEST</p>
            </div>
            <span class="st-status-pill report">Reported</span>
          </div>
          <ul class="st-activity-list">
            <li>26 repositories reviewed for visibility, alerts, scanning and security settings.</li>
            <li>npm audit summaries generated by production and all-dependency scope.</li>
            <li>gitleaks summaries produced, with follow-up queues identified where needed.</li>
          </ul>
        </div>
      </article>

      <article class="st-activity-card">
        <div class="st-activity-visual">
          <img src="/og-default.png" alt="" loading="lazy" />
          <div class="st-activity-icon">SYS</div>
        </div>
        <div class="st-activity-body">
          <div class="st-activity-top">
